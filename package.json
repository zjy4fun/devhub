{
  "name": "@zjy4fun/devhub",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "version": "0.2.2",
  "description": "DevHub TUI for managing local developer environment configuration",
  "type": "module",
  "bin": {
    "devhub": "dist/cli.js"
  },
  "scripts": {
    "dev": "node --import tsx src/cli.tsx",
    "build": "tsup src/cli.tsx --format esm --dts --clean",
    "start": "node dist/cli.js"
  },
  "keywords": [
    "tui",
    "ink",
    "developer-tools",
    "git",
    "ssh",
    "nodejs"
  ],
  "author": "",
  "license": "MIT",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@inkjs/ui": "^2.0.0",
    "chalk": "^5.6.2",
    "ini": "^6.0.0",
    "ink": "^7.0.0",
    "ink-select-input": "^6.2.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "react": "^19.2.0",
    "ssh-config": "^5.1.0",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
